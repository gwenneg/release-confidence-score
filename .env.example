# GitHub configuration
RCS_GITHUB_TOKEN=your_github_token_here

# GitLab configuration
RCS_GITLAB_BASE_URL=https://gitlab.cee.redhat.com/
#RCS_GITLAB_SKIP_SSL_VERIFY=true
RCS_GITLAB_TOKEN=your_gitlab_token_here

# Logging configuration
#RCS_LOG_FORMAT=json
#RCS_LOG_LEVEL=info

# GCP service account key (base64-encoded JSON) - REQUIRED
RCS_GOOGLE_SA_KEY_B64=your_base64_encoded_service_account_json_here

# Model selection (claude or gemini)
#RCS_MODEL_PROVIDER=claude

# Claude configuration - REQUIRED when using RCS_MODEL_PROVIDER=claude
RCS_CLAUDE_MODEL_API=https://your-claude-api-host.example.com
RCS_CLAUDE_MODEL_ID=claude-sonnet-4@20250514

# Gemini configuration - REQUIRED when using RCS_MODEL_PROVIDER=gemini
#RCS_GEMINI_MODEL_API=https://your-gemini-api-host.example.com
#RCS_GEMINI_MODEL_ID=gemini-2.5-pro

# Additional model configuration
#RCS_MODEL_MAX_RESPONSE_TOKENS=4096
#RCS_MODEL_SKIP_SSL_VERIFY=true
#RCS_MODEL_TIMEOUT_SECONDS=120

# System prompt version
#RCS_SYSTEM_PROMPT_VERSION=v1

# Scoring thresholds
#RCS_SCORE_THRESHOLD_AUTO_DEPLOY=80
#RCS_SCORE_THRESHOLD_REVIEW_REQUIRED=60

# Feedback
# URL of the feedback form shown at the bottom of every generated report.
# Leave unset to omit the feedback link.
#RCS_FEEDBACK_URL=https://forms.gle/your-form-id
